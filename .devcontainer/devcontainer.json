// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/cpp
{
	"name": "FSB Dev Container",

	// Uncomment to use cached image instead of building locally
	// "image": "ghcr.io/fancysafebot/devcontainer:stable",

	"build": {
		"dockerfile": "./Dockerfile",
        "context": ".."
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	"postCreateCommand": "./scripts/build.sh 'debug'",

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"settings": {
				"C_Cpp.intelliSenseEngine": "disabled",
				"clangd.arguments": [
					"--compile-commands-dir=/workspaces/fsb-library/build/debug/"
				],
				"cmake.useCMakePresets": "always",
				"cmake.configureEnvironment": {
					"CC": "clang",
					"CXX": "clang++",
					"FSB_ENABLE_DOCS": "ON",
					"FSB_ENABLE_EXAMPLES": "ON"
				}
			},
			"extensions": [
				"ms-python.python",
				"ms-vscode.cpptools-extension-pack",
				"matepek.vscode-catch2-test-adapter",
				"njpwerner.autodocstring",
				"llvm-vs-code-extensions.vscode-clangd"
			]
		}
	}

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
