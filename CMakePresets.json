{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "common",
      "hidden": true,
      "binaryDir": "build/${presetName}",
      "cacheVariables": {
        "CPM_SOURCE_CACHE": "${sourceDir}/build/CPM"
      }
    },
    {
      "name": "docs",
      "displayName": "Documentation",
      "inherits": "common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "FSB_ENABLE_DOCS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage",
      "inherits": "common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Coverage"
      }
    },
    {
      "name": "instrument",
      "displayName": "Instrumentation with address and memory sanitizers",
      "inherits": "common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Instrument"
      }
    },
    {
      "name": "codeql",
      "displayName": "Build for CodeQL Analysis",
      "inherits": "debug",
      "cacheVariables": {
        "FSB_BUILD_OPENBLAS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "displayName": "FSB Library Release Build",
      "configurePreset": "release",
      "targets": ["fsbcore_test", "fsbposix_test", "fsburdf_test"]
    },
    {
      "name": "debug",
      "displayName": "FSB Library Debug Build",
      "configurePreset": "debug",
      "targets": ["fsbcore_test", "fsbposix_test", "fsburdf_test"]
    },
    {
      "name": "docs",
      "displayName": "FSB Library Documentation",
      "configurePreset": "docs",
      "targets": ["Documentation-FancySafeBot"]
    },
    {
      "name": "coverage",
      "displayName": "FSB Library Test Coverage Build",
      "configurePreset": "coverage",
      "targets": ["fsbcore_test", "fsbposix_test", "fsburdf_test"]
    },
    {
      "name": "instrument",
      "displayName": "FSB Library Test Address Sanitizer Build",
      "configurePreset": "instrument",
      "targets": ["fsbcore_test", "fsbposix_test", "fsburdf_test"]
    },
    {
      "name": "codeql",
      "displayName": "FSB Library CodeQL Build",
      "configurePreset": "codeql",
      "targets": ["fsbcore_test", "fsbposix_test"]
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "displayName": "FSB Library Debug Tests",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "jobs": 6
      }
    },
    {
      "name": "coverage",
      "displayName": "FSB Library Coverage Tests",
      "configurePreset": "coverage",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "jobs": 6
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "test",
      "displayName": "FSB Library Test Workflow (Debug)",
      "steps": [
        {
          "type": "configure",
          "name": "debug"
        },
        {
          "type": "build",
          "name": "debug"
        },
        {
          "type": "test",
          "name": "debug"
        }
      ]
    },
    {
      "name": "coverage",
      "displayName": "FSB Library Coverage Workflow",
      "steps": [
        {
          "type": "configure",
          "name": "coverage"
        },
        {
          "type": "build",
          "name": "coverage"
        },
        {
          "type": "test",
          "name": "coverage"
        }
      ]
    },
    {
      "name": "codeql",
      "displayName": "FSB Library CodeQL Workflow",
      "steps": [
        {
          "type": "configure",
          "name": "codeql"
        },
        {
          "type": "build",
          "name": "codeql"
        }
      ]
    }
  ]
}
