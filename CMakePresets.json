{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "common",
      "hidden": true,
      "binaryDir": "build/${presetName}",
      "cacheVariables": {
        "CPM_SOURCE_CACHE": "${sourceDir}/build/CPM"
      }
    },
    {
      "name": "dev-debug",
      "displayName": "Dev Debug",
      "inherits": "common",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Debug",
        "FSB_ENABLE_DOCS": "ON",
        "FSB_ENABLE_EXAMPLES": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage",
      "inherits": "common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Coverage"
      }
    },
    {
      "name": "instrument",
      "displayName": "Instrumentation with address and memory sanitizers",
      "inherits": "common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Instrument"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev-debug",
      "displayName": "FSB Dev Container",
      "configurePreset": "dev-debug",
      "targets": ["fsbcore_test", "fsbposix_test", "fsburdf_test", "fsb_examples"]
    },
    {
      "name": "release",
      "displayName": "FSB Library Release Build",
      "configurePreset": "release",
      "targets": ["fsbcore_test", "fsbposix_test", "fsburdf_test"]
    },
    {
      "name": "debug",
      "displayName": "FSB Library Debug Build",
      "configurePreset": "debug",
      "targets": ["fsbcore_test", "fsbposix_test", "fsburdf_test"]
    },
    {
      "name": "doc",
      "displayName": "FSB Library Documentation",
      "configurePreset": "dev-debug",
      "targets": ["Documentation-FancySafeBot"]
    },
    {
      "name": "coverage",
      "displayName": "FSB Library Test Coverage Build",
      "configurePreset": "coverage",
      "targets": ["fsbcore_test", "fsbposix_test", "fsburdf_test"]
    },
    {
      "name": "instrument",
      "displayName": "FSB Library Test Address Sanitizer Build",
      "configurePreset": "instrument",
      "targets": ["fsbcore_test", "fsbposix_test", "fsburdf_test"]
    }
  ]
}
